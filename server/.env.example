PORT=5000
NODE_ENV=development
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<your-project-ref>.supabase.co:5432/postgres
SUPABASE_POOLER_URL=postgresql://postgres.<your-project-ref>:[YOUR-PASSWORD]@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
AUTH_TABLE=registration
AUTH_FORCE_DB=true
JWT_SECRET=change-this-to-a-very-strong-secret
SECRET_KEY=change-this-to-a-very-strong-secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:5000
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-app-password
EMAIL_FROM=your-email@example.com
VERIFICATION_EMAIL_HOST=smtp.gmail.com
VERIFICATION_EMAIL_PORT=587
VERIFICATION_EMAIL_USER=your-email@example.com
VERIFICATION_EMAIL_PASS=your-email-app-password
VERIFICATION_EMAIL_FROM=your-email@example.com


